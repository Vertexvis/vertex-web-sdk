{
  "$schema": "http://json.schemastore.org/tsconfig",
  "extends": "@vertexwebsdk/build/tsconfig-web",
  "compilerOptions": {
    "inlineSources": false,
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "jsx": "react",
    "jsxFactory": "h",
  },
  "include": [
    "src",
    "types/*.d.ts",
    "src/components.d.ts",
    "src/regl-shape.d.ts",
  ],
  "exclude": ["dist", "node_modules", "**/*.spec.ts", "**/*.spec.tsx"],
}
