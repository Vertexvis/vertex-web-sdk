{
  "name": "root",
  "private": true,
  "nextVersionBump": "major",
  "devDependencies": {
    "eslint": "^8.57.1",
    "lerna": "^6.6.2",
    "semver": "^7.5.2",
    "typedoc": "^0.28.14",
    "typescript": "^5.2.0",
    "vite": "^8.0.10"
  },
  "scripts": {
    "postinstall": "yarn generate:vscode-workspace && yarn generate:npmrc",
    "generate:vscode-workspace": "./scripts/generate_vscode_workspace.sh",
    "generate:docs": "lerna run generate:docs && typedoc --tsconfig tsconfig.docs.json",
    "generate:npmrc": "./scripts/generate_npmrc.sh",
    "build": "lerna run build",
    "release": "./scripts/release.sh",
    "release:ask": "ASK_VERSION=true ./scripts/release.sh",
    "test": "lerna run test",
    "test:ci": "lerna run test:ci",
    "test:coverage": "lerna run test:coverage",
    "lint": "lerna run lint",
    "format": "lerna run format",
    "clean": "lerna clean",
    "validate": "yarn build && yarn test && yarn lint",
    "version:bump": "./scripts/version_bump.sh",
    "examples:start": "vite --host 0.0.0.0 --port 8080 --strictPort"
  },
  "workspaces": {
    "packages": [
      "internal/*",
      "packages/*"
    ],
    "nohoist": [
      "**/@stencil/react-output-target",
      "**/@stencil/react-output-target/**",
      "**/@stencil/vue-output-target",
      "**/@stencil/vue-output-target/**"
    ]
  },
  "resolutions": {
    "@types/react": "^19",
    "minimatch": "^6.2.3",
    "semver": "^7.5.2"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
